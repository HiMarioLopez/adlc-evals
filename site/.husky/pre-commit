#!/bin/sh
# Exit on any error
set -e

# Project directory where ultracite config lives
PROJECT_DIR="$(dirname "$0")/.."

# Get staged files (only formattable extensions)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR -- '*.ts' '*.tsx' '*.js' '*.jsx' '*.json' '*.css')

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# Run formatter/linter only on staged files
cd "$PROJECT_DIR"
echo "$STAGED_FILES" | xargs bun x ultracite fix

# Check if formatter modified any of the staged files
MODIFIED=$(echo "$STAGED_FILES" | xargs git diff --name-only --)
if [ -n "$MODIFIED" ]; then
  echo ""
  echo "⚠️  Ultracite modified files. Please review and re-stage:"
  echo "$MODIFIED"
  echo ""
  echo "Run: git add -u && git commit"
  exit 1
fi

exit 0
